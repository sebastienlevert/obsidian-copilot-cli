{
  "name": "obsidian-copilot",
  "version": "0.1.0",
  "description": "GitHub Copilot CLI terminal integration for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --dev",
    "build": "node esbuild.config.mjs",
    "rebuild-pty": "electron-rebuild -f -w node-pty"
  },
  "keywords": [
    "obsidian",
    "copilot",
    "terminal",
    "ai"
  ],
  "author": "Sébastien Levert",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "obsidian": "latest",
    "typescript": "^5.4.0",
    "@electron/rebuild": "^3.6.0"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "node-pty": "^1.0.0"
